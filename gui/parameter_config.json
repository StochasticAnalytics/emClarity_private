{
  "version": "1.0",
  "description": "emClarity parameter configuration shared between MATLAB and GUI",
  "parameters": {
    "PIXEL_SIZE": {
      "display_name": "Pixel Size",
      "description": "Pixel size (e.g., 1.0 for 1.0 Angstrom)",
      "param_type": "float",
      "si_default": 1.0e-10,
      "si_min": 1e-12,
      "si_max": 100e-10,
      "gui_unit": "Angstrom",
      "gui_scaling_factor": 1e10,
      "display_decimals": 4,
      "required": true,
      "category": "CTF"
    },
    "Cs": {
      "display_name": "Spherical Aberration",
      "description": "Spherical aberration coefficient",
      "param_type": "float",
      "si_default": 2.7e-3,
      "si_min": 1e-6,
      "si_max": 10e-3,
      "gui_unit": "mm",
      "gui_scaling_factor": 1000,
      "display_decimals": 3,
      "required": true,
      "category": "CTF"
    },
    "VOLTAGE": {
      "display_name": "Accelerating Voltage",
      "description": "Accelerating voltage",
      "param_type": "choice",
      "si_default": 300e3,
      "si_min": 20e3,
      "si_max": 1000e3,
      "gui_unit": "keV",
      "gui_scaling_factor": 0.001,
      "display_decimals": 0,
      "choices": ["100", "120", "200", "300"],
      "required": true,
      "category": "CTF"
    },
    "AMPCONT": {
      "display_name": "Amplitude Contrast",
      "description": "Percent amplitude contrast (0.0-1.0)",
      "param_type": "float",
      "si_default": 0.04,
      "si_min": 0.0,
      "si_max": 1.0,
      "gui_unit": "",
      "gui_scaling_factor": 1.0,
      "display_decimals": 3,
      "required": true,
      "category": "CTF"
    },
    "defEstimate": {
      "display_name": "Defocus Estimate",
      "description": "Initial defocus estimate",
      "param_type": "float",
      "si_default": 3.5e-6,
      "si_min": 0.5e-6,
      "si_max": 10e-6,
      "gui_unit": "micron",
      "gui_scaling_factor": 1e6,
      "display_decimals": 2,
      "required": false,
      "category": "CTF"
    },
    "defWindow": {
      "display_name": "Defocus Window",
      "description": "Defocus search window",
      "param_type": "float",
      "si_default": 1.75e-6,
      "si_min": 0.1e-6,
      "si_max": 5e-6,
      "gui_unit": "micron",
      "gui_scaling_factor": 1e6,
      "display_decimals": 2,
      "required": false,
      "category": "CTF"
    },
    "defCutOff": {
      "display_name": "Defocus Cutoff",
      "description": "Resolution cutoff for defocus estimation",
      "param_type": "float",
      "si_default": 6e-10,
      "si_min": 3e-10,
      "si_max": 20e-10,
      "gui_unit": "Angstrom",
      "gui_scaling_factor": 1e10,
      "display_decimals": 1,
      "required": false,
      "category": "CTF"
    },
    "max_ctf3dDepth": {
      "display_name": "Max CTF 3D Depth",
      "description": "Maximum depth for 3D CTF correction",
      "param_type": "float",
      "si_default": 100e-9,
      "si_min": 1e-9,
      "si_max": 1000e-9,
      "gui_unit": "nm",
      "gui_scaling_factor": 1e9,
      "display_decimals": 1,
      "required": false,
      "category": "CTF"
    },
    "nGPUs": {
      "display_name": "Number of GPUs",
      "description": "Number of GPUs to use for computation",
      "param_type": "int",
      "si_default": 1,
      "si_min": 1,
      "si_max": 1000,
      "gui_unit": "",
      "gui_scaling_factor": 1,
      "display_decimals": 0,
      "required": true,
      "category": "System"
    },
    "nCpuCores": {
      "display_name": "Number of CPU Cores",
      "description": "Number of CPU cores to use",
      "param_type": "int",
      "si_default": 8,
      "si_min": 1,
      "si_max": 1000,
      "gui_unit": "",
      "gui_scaling_factor": 1,
      "display_decimals": 0,
      "required": true,
      "category": "System"
    },
    "Ali_samplingRate": {
      "display_name": "Alignment Sampling Rate",
      "description": "Sampling rate for alignment (binning factor)",
      "param_type": "int",
      "si_default": 3,
      "si_min": 1,
      "si_max": 10,
      "gui_unit": "",
      "gui_scaling_factor": 1,
      "display_decimals": 0,
      "required": false,
      "category": "Alignment"
    },
    "Ali_mRadius": {
      "display_name": "Alignment Mask Radius",
      "description": "Mask radius [x, y, z]",
      "param_type": "vector",
      "si_default": [220e-10, 220e-10, 164e-10],
      "si_min": [10e-10, 10e-10, 10e-10],
      "si_max": [1000e-10, 1000e-10, 1000e-10],
      "gui_unit": "Angstrom",
      "gui_scaling_factor": 1e10,
      "display_decimals": 0,
      "vector_size": 3,
      "required": false,
      "category": "Alignment"
    },
    "Ali_mCenter": {
      "display_name": "Alignment Mask Center",
      "description": "Mask center [x, y, z]",
      "param_type": "vector",
      "si_default": [0, 0, 0],
      "si_min": [-500e-10, -500e-10, -500e-10],
      "si_max": [500e-10, 500e-10, 500e-10],
      "gui_unit": "Angstrom",
      "gui_scaling_factor": 1e10,
      "display_decimals": 0,
      "vector_size": 3,
      "required": false,
      "category": "Alignment"
    },
    "Raw_angleSearch": {
      "display_name": "Raw Angle Search",
      "description": "Angle search parameters [phi_min, phi_max, theta_max, step]",
      "param_type": "vector",
      "si_default": [0, 0, 180, 3],
      "si_min": [0, 0, 0, 0],
      "si_max": [180, 360, 180, 360],
      "gui_unit": "degrees",
      "gui_scaling_factor": 1,
      "display_decimals": 0,
      "vector_size": 4,
      "vector_bounds": [[0, 180], [0, 360], [0, 180], [0, 360]],
      "required": false,
      "category": "Alignment"
    },
    "symmetry": {
      "display_name": "Symmetry",
      "description": "Particle symmetry (C1, C2, C12, D2, O)",
      "param_type": "choice",
      "si_default": "C1",
      "choices": ["C1", "C2", "C3", "C4", "C5", "C6", "C7", "C8", "C9", "C10", "C11", "C12", "D2", "O", "I"],
      "gui_unit": "",
      "gui_scaling_factor": 1,
      "display_decimals": 0,
      "required": true,
      "category": "Alignment"
    },
    "move_reference_by_com": {
      "display_name": "Move Reference by COM",
      "description": "Shifts 3d reference to estimate of center of mass prior to aligning subtomos. Most helpful initially, may cause problems with membrane proteins or multi-reference alignments.",
      "param_type": "bool",
      "si_default": false,
      "gui_unit": "",
      "gui_scaling_factor": 1,
      "display_decimals": 0,
      "required": false,
      "category": "Alignment"
    },
    "symmetry_constrained_search": {
      "display_name": "Constrained Symmetry Search",
      "description": "Only implemented for CX symmetry, search the in-plane step around each symmetry related position.",
      "param_type": "bool",
      "si_default": false,
      "gui_unit": "",
      "gui_scaling_factor": 1,
      "display_decimals": 0,
      "required": false,
      "category": "Alignment"
    },
    "Pca_clusters": {
      "display_name": "PCA Clusters",
      "description": "Number of clusters for PCA classification",
      "param_type": "vector",
      "si_default": [64, 144],
      "si_min": [1, 1],
      "si_max": [1000, 1000],
      "gui_unit": "",
      "gui_scaling_factor": 1,
      "display_decimals": 0,
      "vector_size": 2,
      "required": true,
      "category": "Processing"
    },
    "Tmp_bandpass": {
      "display_name": "Template Bandpass",
      "description": "Bandpass filter parameters [low_freq, high_freq, falloff]",
      "param_type": "vector",
      "si_default": [0.01, 1200, 25],
      "si_min": [0.001, 100, 1],
      "si_max": [1.0, 10000, 100],
      "gui_unit": "1/Angstrom",
      "gui_scaling_factor": 1,
      "display_decimals": 3,
      "vector_size": 3,
      "required": false,
      "category": "Template Search"
    },
    "Tmp_angleSearch": {
      "display_name": "Template Angle Search",
      "description": "Template angle search parameters [phi_range, phi_step, theta_range, theta_step]",
      "param_type": "vector",
      "si_default": [180, 12, 180, 12],
      "si_min": [0, 1, 0, 1],
      "si_max": [360, 90, 360, 90],
      "gui_unit": "degrees",
      "gui_scaling_factor": 1,
      "display_decimals": 0,
      "vector_size": 4,
      "required": false,
      "category": "Template Search"
    },
    "Tmp_samplingRate": {
      "display_name": "Template Sampling Rate",
      "description": "Sampling rate for template matching",
      "param_type": "int",
      "si_default": 4,
      "si_min": 1,
      "si_max": 10,
      "gui_unit": "",
      "gui_scaling_factor": 1,
      "display_decimals": 0,
      "required": false,
      "category": "Template Search"
    },
    "Rec_boxSize": {
      "display_name": "Reconstruction Box Size",
      "description": "Box size for reconstruction [x, y, z]",
      "param_type": "vector",
      "si_default": [512, 512, 768],
      "si_min": [64, 64, 64],
      "si_max": [2048, 2048, 2048],
      "gui_unit": "pixels",
      "gui_scaling_factor": 1,
      "display_decimals": 0,
      "vector_size": 3,
      "required": false,
      "category": "Reconstruction"
    },
    "particleRadius": {
      "display_name": "Particle Radius",
      "description": "Particle radius [x, y, z]",
      "param_type": "vector",
      "si_default": [180e-10, 180e-10, 150e-10],
      "si_min": [10e-10, 10e-10, 10e-10],
      "si_max": [1000e-10, 1000e-10, 1000e-10],
      "gui_unit": "Angstrom",
      "gui_scaling_factor": 1e10,
      "display_decimals": 0,
      "vector_size": 3,
      "required": false,
      "category": "Processing"
    },
    "beadDiameter": {
      "display_name": "Bead Diameter",
      "description": "Gold fiducial diameter",
      "param_type": "float",
      "si_default": 10e-9,
      "si_min": 5e-9,
      "si_max": 20e-9,
      "gui_unit": "nm",
      "gui_scaling_factor": 1e9,
      "display_decimals": 1,
      "required": false,
      "category": "Utilities"
    },
    "startingAngle": {
      "display_name": "Starting Angle",
      "description": "Starting tilt angle",
      "param_type": "float",
      "si_default": 0,
      "si_min": -90,
      "si_max": 90,
      "gui_unit": "degrees",
      "gui_scaling_factor": 1,
      "display_decimals": 1,
      "required": false,
      "category": "Project Setup"
    },
    "projectName": {
      "display_name": "Project Name",
      "description": "Name for the emClarity project",
      "param_type": "string",
      "si_default": "new_project",
      "gui_unit": "",
      "gui_scaling_factor": 1,
      "display_decimals": 0,
      "required": true,
      "category": "Project Setup"
    },
    "workingDirectory": {
      "display_name": "Working Directory",
      "description": "Base directory for project files",
      "param_type": "file",
      "si_default": "./",
      "gui_unit": "",
      "gui_scaling_factor": 1,
      "display_decimals": 0,
      "required": true,
      "category": "Project Setup"
    },
    "tiltSeriesPattern": {
      "display_name": "Tilt Series Pattern",
      "description": "File pattern for tilt series (e.g., *.mrc, *.st)",
      "param_type": "string",
      "si_default": "*.mrc",
      "gui_unit": "",
      "gui_scaling_factor": 1,
      "display_decimals": 0,
      "required": true,
      "category": "Project Setup"
    },
    "deltaZTolerance": {
      "display_name": "Delta Z Tolerance",
      "description": "Z tolerance for defocus estimation",
      "param_type": "float",
      "si_default": 100e-9,
      "si_min": 10e-9,
      "si_max": 300e-9,
      "gui_unit": "nm",
      "gui_scaling_factor": 1e9,
      "display_decimals": 1,
      "required": false,
      "category": "CTF"
    },
    "zShift": {
      "display_name": "Z Shift",
      "description": "Z shift parameter",
      "param_type": "float",
      "si_default": 150e-9,
      "si_min": 100e-9,
      "si_max": 300e-9,
      "gui_unit": "nm",
      "gui_scaling_factor": 1e9,
      "display_decimals": 1,
      "required": false,
      "category": "CTF"
    },
    "whitenPS": {
      "display_name": "Whitening Parameters",
      "description": "Power spectrum whitening: [whiten_flag, filter_flag, additive_term]",
      "param_type": "vector",
      "si_default": [0, 0, 0.5],
      "si_min": [0, 0, 0],
      "si_max": [1, 1, 1],
      "gui_unit": "",
      "gui_scaling_factor": 1,
      "display_decimals": 2,
      "vector_size": 3,
      "required": false,
      "category": "CTF"
    }
  },
  "categories": [
    "System",
    "CTF", 
    "Alignment",
    "Template Search",
    "Processing",
    "Reconstruction",
    "Utilities",
    "Project Setup"
  ]
}
